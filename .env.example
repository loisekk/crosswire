# Dev.to
DEVTO_API_KEY=your_devto_api_key
DEVTO_USERNAME=your_devto_username

# Hashnode
HASHNODE_API_KEY=your_hashnode_api_key
HASHNODE_PUBLICATION_ID=your_publication_id
HASHNODE_PUBLICATION_HOST=your-publication.hashnode.dev

# X (Twitter) - Note: Basic plan costs $100/month
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret

# Reddit
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# LinkedIn
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=your_person_urn

# Indeed (Browser Automation)
INDEED_EMAIL=your_indeed_email
INDEED_PASSWORD=your_indeed_password

# Naukri (Browser Automation)
NAUKRI_EMAIL=your_naukri_email
NAUKRI_PASSWORD=your_naukri_password

# Webhook Server
WEBHOOK_PORT=5678
